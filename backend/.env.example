DATABASE_URL=postgresql+asyncpg://pranascan:pranascan_dev_password@localhost:5432/pranascan
# Keep this false when using Alembic-managed local databases.
# AUTO_CREATE_TABLES=false
SECRET_KEY=replace-me-with-a-long-random-secret
ENVIRONMENT=development
LOG_LEVEL=info
DEBUG=false

# Optional local beta gate
# BETA_ONBOARDING_ENABLED=true
# BETA_SEED_INVITE_CODE=CLOSED50
# BETA_SEED_INVITE_COHORT=general_beta
# BETA_SEED_INVITE_MAX_REDEMPTIONS=50

# Optional delivery channels
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# WHATSAPP_ENABLED=false
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_RECIPIENT_PHONE=

# Optional ABHA/ABDM integration
# ABHA_ENABLED=false
# ABHA_SANDBOX=true
# ABHA_GATEWAY_URL=https://dev.abdm.gov.in/gateway
# ABHA_CLIENT_ID=
# ABHA_CLIENT_SECRET=

# Optional internal agent endpoint
# AGENT_SECRET_KEY=
